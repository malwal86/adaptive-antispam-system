{
  "uid": "antispam-ops",
  "title": "Living Anti-Spam — Ops",
  "tags": ["antispam", "ops"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Fast-path p95 latency (budget 100ms)",
      "description": "p95 of the synchronous (hard-rule + model) decision path. Red past the 100ms budget.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(antispam_decision_latency_seconds_bucket{route=~\"HARD_RULE|MODEL\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "LLM-routed fraction",
      "description": "Share of decisions escalated to the LLM. The cost lever — the PRD targets ~5%.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(antispam_decision_route_total{route=\"LLM\"}[$__rate_interval])) / clamp_min(sum(rate(antispam_decision_route_total[$__rate_interval])), 0.0001)",
          "legendFormat": "routed"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "LLM spend this process (cumulative)",
      "description": "Running antispam_llm_cost_usd_total. Compare with the cap panel below.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4 },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "antispam_llm_cost_usd_total",
          "legendFormat": "cost"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Fast-path decision latency vs 100ms budget",
      "description": "p50/p95/p99 of the synchronous (hard-rule + model) path. The red line is the <100ms budget.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(antispam_decision_latency_seconds_bucket{route=~\"HARD_RULE|MODEL\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(antispam_decision_latency_seconds_bucket{route=~\"HARD_RULE|MODEL\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(antispam_decision_latency_seconds_bucket{route=~\"HARD_RULE|MODEL\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Route mix (route_used) over time",
      "description": "Decisions/sec by final route. The ~95/5 fast-vs-LLM split is the cost story.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(antispam_decision_route_total[$__rate_interval])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Decisions by tier",
      "description": "Decisions/sec by verdict tier (allow/warn/quarantine/block).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(antispam_decision_tier_total[$__rate_interval])) by (tier)",
          "legendFormat": "{{tier}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LLM cost vs cap",
      "description": "Cumulative spend (antispam_llm_cost_usd_total) against the live daily/monthly caps. Budget-remaining is the gap.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "line", "fillOpacity": 8 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*cap.*" },
            "properties": [
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "antispam_llm_cost_usd_total",
          "legendFormat": "spend"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "antispam_llm_budget_cap_usd{scope=\"daily\"}",
          "legendFormat": "daily cap"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "antispam_llm_budget_cap_usd{scope=\"monthly\"}",
          "legendFormat": "monthly cap"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Degraded-mode frequency",
      "description": "Fail-degrades/sec: synchronous fast-path degrades, async quarantine-pending degrades, and SLA timeouts.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(antispam_decision_degraded_total[$__rate_interval])",
          "legendFormat": "fast-path degrade"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(antispam_llm_resolution_total{state=\"degraded\"}[$__rate_interval])",
          "legendFormat": "async degrade"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(antispam_llm_sla_timeout_total[$__rate_interval])",
          "legendFormat": "SLA timeout"
        }
      ]
    }
  ]
}
